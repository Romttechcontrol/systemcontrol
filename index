<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Inter,sans-serif;background:#f5f7fb;color:#263238}
.sidebar{position:fixed;left:0;top:0;width:250px;height:100vh;background:#0d4d86;color:#fff;padding:22px}
.logo{font-size:24px;font-weight:700;margin-bottom:35px}
.menu a{display:flex;align-items:center;gap:12px;padding:13px 15px;margin-bottom:8px;color:#fff;text-decoration:none;border-radius:10px;transition:.2s}
.menu a.active,.menu a:hover{background:rgba(255,255,255,.15)}
.content{margin-left:250px;padding:25px}
.header{display:flex;justify-content:space-between;align-items:center;background:#fff;padding:18px 25px;border-radius:14px;box-shadow:0 4px 12px rgba(0,0,0,.08)}
.user{display:flex;align-items:center;gap:12px}
.avatar{width:42px;height:42px;border-radius:50%;background:#0d4d86;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:bold}
.steps{display:grid;grid-template-columns:repeat(5,1fr);gap:15px;margin:25px 0}
.step,.card,.panel{background:#fff;border-radius:14px;padding:18px;box-shadow:0 3px 10px rgba(0,0,0,.08)}
.step small{color:#777}
.cards{display:grid;grid-template-columns:repeat(4,1fr);gap:15px}
.card h2{color:#0d4d86;margin-bottom:6px}
.bottom{display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-top:20px}
table{width:100%;border-collapse:collapse}
th,td{padding:12px;border-bottom:1px solid #eee;text-align:left;font-size:14px}
.badge{padding:4px 10px;border-radius:20px;background:#d1fae5;color:#166534;font-size:12px}
footer{text-align:center;color:#888;margin-top:30px}
@media(max-width:1100px){
.steps,.cards,.bottom{grid-template-columns:1fr}
.content{margin-left:0}
.sidebar{position:relative;width:100%;height:auto}
}
</style>
</head>
